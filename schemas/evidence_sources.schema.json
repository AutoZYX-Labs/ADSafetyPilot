{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adsafetypilot.autozyx.com/schemas/evidence_sources.schema.json",
  "title": "ADSafetyPilot Evidence Sources",
  "type": "object",
  "required": ["pack_id", "version", "sources", "data_requirements"],
  "properties": {
    "pack_id": {"type": "string"},
    "version": {"type": "string"},
    "status": {"type": "string"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "relevance", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "path": {"type": "string"},
          "relevance": {"type": "string"},
          "confidence": {"type": "string"}
        }
      }
    },
    "data_requirements": {"type": "object"}
  }
}
